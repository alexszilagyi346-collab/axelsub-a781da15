# ============================================================
# AxelSub – Környezeti változók sablonja
# Másold le ezt a fájlt .env névvel és töltsd ki az értékeket!
# ============================================================

# --- Supabase (kötelező) ---
# Supabase project URL (Project Settings → API → Project URL)
VITE_SUPABASE_URL=https://PROJEKT_ID.supabase.co

# Supabase projekt azonosító
VITE_SUPABASE_PROJECT_ID=PROJEKT_ID

# Supabase anon/public kulcs (Project Settings → API → anon public)
VITE_SUPABASE_PUBLISHABLE_KEY=eyJ...

# Supabase service_role kulcs (Project Settings → API → service_role) – TITKOS, ne oszd meg!
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Brevo email küldés (opcionális, de az email értesítőkhöz szükséges) ---
# Brevo API kulcs (app.brevo.com → API Keys)
BREVO_API_KEY=xkeysib-...

# A feladó email cím (Brevo-ban hitelesített domain-ről)
BREVO_SENDER_EMAIL=noreply@axelsub.eu
